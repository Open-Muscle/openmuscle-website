---
/**
 * 3D Forearm Cylinder with sensor heatmap + Style C hand animation
 * Shows sensors wrapped around a cylinder with predicted hand movement above
 */
---

<div class="forearm-viz-wrap">
  <div class="flex items-center justify-between mb-3">
    <h3 class="text-lg font-semibold text-text-base">FlexGrid Sensor Band on Forearm</h3>
    <div class="flex items-center gap-3 text-sm text-text-base/60">
      <button id="forearm-play" class="px-3 py-1 rounded bg-orange-primary text-white hover:bg-orange-bold transition-colors">⏸ Pause</button>
      <select id="forearm-speed" class="px-2 py-1 rounded border border-blue-light bg-white text-text-base text-sm">
        <option value="1">1x</option>
        <option value="2" selected>2x</option>
        <option value="4">4x</option>
      </select>
      <span id="forearm-frame" class="font-mono">0 / 0</span>
    </div>
  </div>
  <div class="flex justify-center">
    <canvas id="forearm-canvas" class="w-full rounded-xl" style="max-width: 650px; background: rgba(254,249,245,0.6);"></canvas>
  </div>
  <div class="mt-2 flex items-center gap-2 text-xs text-text-base/50">
    <span>Low Pressure</span>
    <div class="flex-1 h-3 rounded" style="background: linear-gradient(to right, #BFE8FF, #6FBEE6, #FF9F63, #FFBFA3);"></div>
    <span>High Pressure</span>
  </div>
</div>

<script>
async function initForearmViz() {
  const canvas = document.getElementById('forearm-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;
  const playBtn = document.getElementById('forearm-play') as HTMLButtonElement;
  const speedSel = document.getElementById('forearm-speed') as HTMLSelectElement;
  const frameSpan = document.getElementById('forearm-frame')!;

  const res = await fetch('/data/flexgrid64_holdout_predictions.json');
  const data = await res.json();

  const rows = data.metadata.sensor_layout.rows; // 4
  const cols = data.metadata.sensor_layout.cols; // 16
  const nSamples = data.metadata.n_samples;      // 683

  // Build sensor frames
  const frames: number[][][] = [];
  let globalMin = Infinity, globalMax = -Infinity;
  for (let s = 0; s < nSamples; s++) {
    const frame: number[][] = [];
    for (let r = 0; r < rows; r++) {
      const row: number[] = [];
      for (let c = 0; c < cols; c++) {
        const val = data.sensor_data[`R${r}C${c}`][s];
        row.push(val);
        if (val < globalMin) globalMin = val;
        if (val > globalMax) globalMax = val;
      }
      frame.push(row);
    }
    frames.push(frame);
  }

  // Label/prediction data for hand
  const fingerNames = ['label_0', 'label_1', 'label_2', 'label_3'];
  const preds: number[][] = fingerNames.map(k => data.predictions[k]);
  const actuals: number[][] = fingerNames.map(k => data.labels[k]);

  // Canvas size
  const W = 650, H = 620;
  canvas.width = W;
  canvas.height = H;

  const actualColor = '#6FBEE6';
  const predictedColor = '#FF9F63';

  function valueToColor(val: number): string {
    const t = (val - globalMin) / (globalMax - globalMin || 1);
    const r = Math.round(111 + (255 - 111) * t);
    const g = Math.round(190 + (159 - 190) * t);
    const b = Math.round(230 + (99 - 230) * t);
    return `rgb(${r},${g},${b})`;
  }

  // ===== CYLINDER GEOMETRY =====
  const cylCx = W / 2, cylTopY = 340, cylRadius = 120, cylHeight = 170;
  const cylEllipseRY = 35; // perspective squash
  const cylBotY = cylTopY + cylHeight;

  function drawCylinder(frame: number[][]) {
    // Draw back half of cylinder (faded)
    ctx.strokeStyle = 'rgba(111,190,230,0.15)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 4]);
    ctx.beginPath();
    ctx.ellipse(cylCx, cylTopY, cylRadius, cylEllipseRY, 0, Math.PI, 2 * Math.PI);
    ctx.stroke();
    ctx.beginPath();
    ctx.ellipse(cylCx, cylBotY, cylRadius, cylEllipseRY, 0, Math.PI, 2 * Math.PI);
    ctx.stroke();
    ctx.setLineDash([]);

    // Cylinder body — side lines
    ctx.strokeStyle = 'rgba(111,190,230,0.2)';
    ctx.lineWidth = 1.5;
    ctx.beginPath(); ctx.moveTo(cylCx - cylRadius, cylTopY); ctx.lineTo(cylCx - cylRadius, cylBotY); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(cylCx + cylRadius, cylTopY); ctx.lineTo(cylCx + cylRadius, cylBotY); ctx.stroke();

    // Sensor patches on front face of cylinder
    // 16 columns wrap around 360°. Front-facing columns: roughly cols 4-12 (center 8-10 visible)
    const colAngleStep = (2 * Math.PI) / cols;
    const rowHeight = cylHeight / rows;

    for (let c = 0; c < cols; c++) {
      const angle = (c / cols) * 2 * Math.PI - Math.PI / 2; // start from front
      const nextAngle = ((c + 1) / cols) * 2 * Math.PI - Math.PI / 2;

      // Only draw front-facing sensors (cos > 0 = facing viewer)
      const midAngle = (angle + nextAngle) / 2;
      const facing = Math.cos(midAngle);
      if (facing < -0.1) continue; // skip back-facing

      const opacity = Math.max(0.15, facing);

      for (let r = 0; r < rows; r++) {
        const color = valueToColor(frame[r][c]);
        const y1 = cylTopY + r * rowHeight;
        const y2 = cylTopY + (r + 1) * rowHeight;

        // Project column edges onto ellipse
        const x1Top = cylCx + Math.sin(angle) * cylRadius;
        const x2Top = cylCx + Math.sin(nextAngle) * cylRadius;
        const y1TopOff = Math.cos(angle) * cylEllipseRY * 0.15;
        const y2TopOff = Math.cos(nextAngle) * cylEllipseRY * 0.15;

        ctx.fillStyle = color;
        ctx.globalAlpha = opacity;
        ctx.beginPath();
        ctx.moveTo(x1Top, y1 + y1TopOff);
        ctx.lineTo(x2Top, y1 + y2TopOff);
        ctx.lineTo(x2Top, y2 + y2TopOff);
        ctx.lineTo(x1Top, y2 + y1TopOff);
        ctx.closePath();
        ctx.fill();

        // Subtle border
        ctx.strokeStyle = 'rgba(255,255,255,0.3)';
        ctx.lineWidth = 0.5;
        ctx.stroke();
        ctx.globalAlpha = 1;
      }
    }

    // Front ellipse top (solid)
    ctx.strokeStyle = 'rgba(111,190,230,0.4)';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.ellipse(cylCx, cylTopY, cylRadius, cylEllipseRY, 0, 0, Math.PI);
    ctx.stroke();

    // Bottom ellipse front
    ctx.beginPath();
    ctx.ellipse(cylCx, cylBotY, cylRadius, cylEllipseRY, 0, 0, Math.PI);
    ctx.stroke();

    // "FlexGrid Band" label on cylinder
    ctx.fillStyle = 'rgba(44,44,44,0.3)';
    ctx.font = '11px Inter, system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('FlexGrid 60-Sensor Band', cylCx, cylBotY + cylEllipseRY + 16);
  }

  // ===== HAND DRAWING (Style C from homepage) =====
  function drawCapsule(x1: number, y1: number, x2: number, y2: number, w1: number, w2: number, fill: string, stroke: string, sw: number) {
    const dx = x2-x1, dy = y2-y1, len = Math.sqrt(dx*dx+dy*dy);
    if (len < 1) return;
    const nx = -dy/len, ny = dx/len;
    ctx.fillStyle = fill; ctx.strokeStyle = stroke; ctx.lineWidth = sw; ctx.lineJoin = 'round';
    ctx.beginPath();
    ctx.arc(x1, y1, w1/2, Math.atan2(ny*w1/2, nx*w1/2), Math.atan2(-ny*w1/2, -nx*w1/2));
    ctx.arc(x2, y2, w2/2, Math.atan2(-ny*w2/2, -nx*w2/2), Math.atan2(ny*w2/2, nx*w2/2));
    ctx.closePath(); ctx.fill(); ctx.stroke();
  }

  const palmW = 80, palmH = 62;
  const fFullLens = [44, 52, 48, 38];
  const fWidths = [17, 17.5, 17, 14.5];

  function drawHand(cx: number, palmY: number, vals: number[], color: string, label: string) {
    const fillColor = color + '15';
    const sw = 2.5;

    ctx.fillStyle = color; ctx.font = 'bold 16px Inter, system-ui, sans-serif'; ctx.textAlign = 'center';
    ctx.fillText(label, cx, palmY - 80);

    // Palm
    const pLeft = cx - palmW/2, r = 16;
    ctx.fillStyle = fillColor; ctx.strokeStyle = color; ctx.lineWidth = sw;
    ctx.beginPath();
    ctx.moveTo(pLeft+r, palmY); ctx.lineTo(pLeft+palmW-r, palmY);
    ctx.arcTo(pLeft+palmW, palmY, pLeft+palmW, palmY+r, r);
    ctx.lineTo(pLeft+palmW, palmY+palmH-r);
    ctx.arcTo(pLeft+palmW, palmY+palmH, pLeft+palmW-r, palmY+palmH, r);
    ctx.lineTo(pLeft+r, palmY+palmH);
    ctx.arcTo(pLeft, palmY+palmH, pLeft, palmY+palmH-r, r);
    ctx.lineTo(pLeft, palmY+r);
    ctx.arcTo(pLeft, palmY, pLeft+r, palmY, r);
    ctx.closePath(); ctx.fill(); ctx.stroke();

    // Metacarpals
    const fStartX = cx - palmW*0.26, fGap = palmW*0.21;
    const fX = [fStartX, fStartX+fGap, fStartX+fGap*2, fStartX+fGap*3];
    ctx.strokeStyle = color + '25'; ctx.lineWidth = 1.2;
    for (let f = 0; f < 4; f++) {
      ctx.beginPath(); ctx.moveTo(cx, palmY + palmH * 0.7); ctx.lineTo(fX[f], palmY); ctx.stroke();
    }
    ctx.beginPath(); ctx.moveTo(cx - palmW*0.2, palmY + palmH * 0.6); ctx.lineTo(pLeft - 2, palmY + palmH*0.28); ctx.stroke();

    for (let f = 0; f < 4; f++) {
      const val = Math.max(0, Math.min(1, vals[f]));
      const fullLen = fFullLens[f];
      const visLen = fullLen * (0.28 + val * 0.72);
      const topY = palmY - visLen;
      const w = fWidths[f], tipR = 9;

      ctx.fillStyle = fillColor; ctx.strokeStyle = color; ctx.lineWidth = sw;
      ctx.beginPath();
      ctx.moveTo(fX[f]-w/2, palmY); ctx.lineTo(fX[f]-w/2, topY+tipR);
      ctx.arcTo(fX[f]-w/2, topY, fX[f], topY, tipR);
      ctx.arcTo(fX[f]+w/2, topY, fX[f]+w/2, topY+tipR, tipR);
      ctx.lineTo(fX[f]+w/2, palmY);
      ctx.closePath(); ctx.fill(); ctx.stroke();

      // Bone line
      ctx.strokeStyle = color + '45'; ctx.lineWidth = 2;
      ctx.beginPath(); ctx.moveTo(fX[f], palmY - 2); ctx.lineTo(fX[f], topY + 5); ctx.stroke();

      // Joints
      const proxEnd = palmY - visLen * 0.5;
      ctx.fillStyle = color + '25'; ctx.strokeStyle = color + '60'; ctx.lineWidth = 1.3;
      ctx.beginPath(); ctx.arc(fX[f], palmY, 5, 0, Math.PI*2); ctx.fill(); ctx.stroke();
      if (visLen > 20) {
        ctx.beginPath(); ctx.arc(fX[f], proxEnd, 4, 0, Math.PI*2); ctx.fill(); ctx.stroke();
      }
      ctx.fillStyle = color;
      ctx.beginPath(); ctx.arc(fX[f], topY + 4, 3, 0, Math.PI*2); ctx.fill();

      // Ghost extension
      ctx.strokeStyle = color + '10'; ctx.lineWidth = 0.8;
      ctx.setLineDash([3, 3]);
      ctx.strokeRect(fX[f]-w/2-1, palmY - fullLen, w+2, fullLen);
      ctx.setLineDash([]);
    }

    // Thumb
    const tVal = (vals[0]+vals[1])*0.3;
    const tLen = 34*(0.45 + tVal*0.55);
    const tBaseX = pLeft - 2, tBaseY = palmY + palmH*0.28;
    const tAngle = -2.07;
    const tEndX = tBaseX + Math.cos(tAngle)*tLen;
    const tEndY = tBaseY + Math.sin(tAngle)*tLen;
    drawCapsule(tBaseX, tBaseY, tEndX, tEndY, 18, 14, fillColor, color, sw);
    ctx.strokeStyle = color + '40'; ctx.lineWidth = 1.5;
    ctx.beginPath(); ctx.moveTo(tBaseX, tBaseY); ctx.lineTo(tEndX, tEndY); ctx.stroke();
    ctx.fillStyle = color + '25'; ctx.strokeStyle = color + '60'; ctx.lineWidth = 1.3;
    ctx.beginPath(); ctx.arc(tBaseX, tBaseY, 5, 0, Math.PI*2); ctx.fill(); ctx.stroke();
    ctx.fillStyle = color;
    ctx.beginPath(); ctx.arc(tEndX, tEndY, 3, 0, Math.PI*2); ctx.fill();
  }

  // ===== DATA FLOW LINES (cylinder → hand) =====
  function drawDataFlow(frameIdx: number) {
    const flowY1 = cylTopY - 10; // top of cylinder
    const flowY2 = 205; // bottom of hand area
    const numLines = 5;

    for (let i = 0; i < numLines; i++) {
      const x = cylCx - 40 + (i * 20);
      const phase = (frameIdx * 0.08 + i * 0.7) % 1;
      const y = flowY2 + (flowY1 - flowY2) * phase;

      ctx.fillStyle = `rgba(111,190,230,${0.15 + phase * 0.25})`;
      ctx.beginPath();
      ctx.arc(x, y, 2.5 + phase * 1.5, 0, Math.PI * 2);
      ctx.fill();
    }

    // Connecting dashed lines
    ctx.strokeStyle = 'rgba(111,190,230,0.1)';
    ctx.lineWidth = 1;
    ctx.setLineDash([3, 6]);
    ctx.beginPath(); ctx.moveTo(cylCx - 30, flowY1); ctx.lineTo(cylCx - 20, flowY2); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(cylCx, flowY1); ctx.lineTo(cylCx, flowY2); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(cylCx + 30, flowY1); ctx.lineTo(cylCx + 20, flowY2); ctx.stroke();
    ctx.setLineDash([]);

    // "ML Inference" label
    ctx.fillStyle = 'rgba(44,44,44,0.25)';
    ctx.font = '10px Inter, system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('ML Inference', cylCx, (flowY1 + flowY2) / 2 + 4);
  }

  // ===== MAIN DRAW =====
  function drawFrame(idx: number) {
    ctx.fillStyle = 'rgba(254,249,245,0.6)';
    ctx.fillRect(0, 0, W, H);

    // Blueprint grid
    ctx.strokeStyle = 'rgba(111,190,230,0.05)';
    ctx.lineWidth = 1;
    for (let x = 0; x < W; x += 20) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke(); }
    for (let y = 0; y < H; y += 20) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke(); }

    // Draw cylinder with sensor data
    drawCylinder(frames[idx]);

    // Draw data flow particles
    drawDataFlow(idx);

    // Draw hands side by side above cylinder
    const handY = 120;
    const aVals = [actuals[0][idx], actuals[1][idx], actuals[2][idx], actuals[3][idx]];
    const pVals = [preds[0][idx], preds[1][idx], preds[2][idx], preds[3][idx]];
    drawHand(W * 0.3, handY, aVals, actualColor, 'Actual (LASK5)');
    drawHand(W * 0.7, handY, pVals, predictedColor, 'Predicted (ML)');

    // Divider between hands
    ctx.strokeStyle = 'rgba(111,190,230,0.12)';
    ctx.lineWidth = 1; ctx.setLineDash([4, 4]);
    ctx.beginPath(); ctx.moveTo(W/2, 30); ctx.lineTo(W/2, 210); ctx.stroke();
    ctx.setLineDash([]);

    frameSpan.textContent = `${idx + 1} / ${nSamples}`;
  }

  // ===== PLAYBACK =====
  let playing = true;
  let frameIdx = 0;
  let intervalId: number | null = null;

  function startPlayback() {
    if (intervalId) clearInterval(intervalId);
    const speed = parseInt(speedSel.value);
    const ms = Math.max(16, Math.round(100 / speed));
    intervalId = window.setInterval(() => {
      frameIdx = (frameIdx + 1) % nSamples;
      drawFrame(frameIdx);
    }, ms);
    playing = true;
    playBtn.textContent = '⏸ Pause';
  }

  function stopPlayback() {
    if (intervalId) clearInterval(intervalId);
    intervalId = null;
    playing = false;
    playBtn.textContent = '▶ Play';
  }

  playBtn.addEventListener('click', () => {
    if (playing) stopPlayback();
    else startPlayback();
  });

  speedSel.addEventListener('change', () => {
    if (playing) startPlayback();
  });

  // Auto-play on load
  drawFrame(0);
  startPlayback();
}

document.addEventListener('DOMContentLoaded', initForearmViz);
</script>
