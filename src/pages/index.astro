---
import BaseLayout from '../layouts/BaseLayout.astro';

// Fetch live GitHub stats at build time
const repoSlugs = [
  'Open-Muscle/OpenMuscle-FlexGrid',
  'Open-Muscle/OpenMuscle-LASK5',
  'Open-Muscle/OpenMuscle-Software',
];

type RepoData = {
  name: string;
  description: string;
  stargazers_count: number;
  forks_count: number;
  language: string | null;
  html_url: string;
  updated_at: string;
};

let repos: RepoData[] = [];
try {
  const results = await Promise.all(
    repoSlugs.map(slug =>
      fetch(`https://api.github.com/repos/${slug}`)
        .then(r => r.json())
    )
  );
  repos = results;
} catch (e) {
  // Fallback: cards will render with static data
}

// Also fetch org-wide stats for the hero
let orgStars = 0;
let orgRepoCount = 0;
try {
  const orgRepos = await fetch('https://api.github.com/orgs/Open-Muscle/repos?per_page=100').then(r => r.json());
  orgStars = orgRepos.reduce((sum: number, r: any) => sum + (r.stargazers_count || 0), 0);
  orgRepoCount = orgRepos.filter((r: any) => r.name !== '.github' && r.name !== 'openmuscle-website').length;
} catch (e) {}

// Repo metadata that the API doesn't capture well
const repoMeta: Record<string, { tags: string[]; desc: string }> = {
  'OpenMuscle-FlexGrid': {
    tags: ['Hardware', 'CERN-OHL-S'],
    desc: '60-sensor (15×4) forearm band with flexible PCB and ESP32-S3. Current flagship hardware.',
  },
  'OpenMuscle-LASK5': {
    tags: ['Hardware', 'ML Training'],
    desc: 'Label Acquiring System K5 — handheld device for capturing ground-truth finger positions for ML training.',
  },
  'OpenMuscle-Software': {
    tags: ['Python', 'MIT'],
    desc: 'Python & MicroPython codebase for data collection, preprocessing, and Random Forest finger prediction.',
  },
};
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="relative overflow-hidden blueprint-grid-dense">
    <!-- Background image -->
    <div class="absolute inset-0 bg-cover bg-center opacity-[0.06]" style="background-image: url('/images/backgrounds/hero-render.png');"></div>
    <!-- Decorative elements -->
    <div class="absolute top-20 left-10 w-32 h-32 rounded-full bg-orange-light/30 blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-40 h-40 rounded-full bg-blue-light/30 blur-3xl"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Text Content -->
        <div class="space-y-8">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-blue-pale/30 border border-blue-primary/20 text-sm text-blue-primary font-medium">
            <span class="w-2 h-2 rounded-full bg-blue-primary animate-pulse"></span>
            Open Source &middot; Open Hardware
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight">
            <span class="text-orange-bold">Prosthetic Sensors</span><br />
            <span class="text-text-base">Open for All</span><br />
            <span class="text-blue-primary">Humanity</span>
          </h1>

          <p class="text-lg text-text-base/70 max-w-lg leading-relaxed">
            OpenMuscle is building affordable, open-source pressure myography sensors
            that predict finger movements using machine learning. No patents. No paywalls.
            Just technology that belongs to everyone.
          </p>

          <div class="flex flex-wrap gap-4">
            <a href="https://github.com/Open-Muscle/OpenMuscle-Hub" target="_blank" class="btn-primary inline-flex items-center gap-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              Explore on GitHub
            </a>
            <a href="/technology" class="btn-secondary inline-flex items-center gap-2">
              How It Works
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>

          <!-- Stats -->
          <div class="flex gap-8 pt-4">
            <div>
              <div class="text-2xl font-bold text-orange-bold">60</div>
              <div class="text-sm text-text-base/50">Sensors (FlexGrid)</div>
            </div>
            <div class="dotted-line-v pl-8">
              <div class="text-2xl font-bold text-blue-primary">~$45</div>
              <div class="text-sm text-text-base/50">Per Device</div>
            </div>
            <div class="dotted-line-v pl-8">
              <div class="text-2xl font-bold text-orange-bold">MIT</div>
              <div class="text-sm text-text-base/50">Licensed</div>
            </div>
          </div>
        </div>

        <!-- Right: Real-time Finger Prediction Replay -->
        <div class="flex justify-center w-full">
          <div class="relative w-full max-w-xl">
            <!-- Animated hands above charts -->
            <div class="flex justify-center mb-3">
              <canvas id="hand-canvas" width="560" height="200" class="w-full max-w-[560px] h-auto rounded-xl" style="background: rgba(254,249,245,0.6);"></canvas>
            </div>
            <!-- 4 finger canvases stacked -->
            <div class="grid grid-cols-2 gap-3" id="finger-grid">
              <div class="finger-chart-box">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs font-semibold text-text-base">Index</span>
                  <span class="finger-r2 text-xs text-text-base/40"></span>
                </div>
                <canvas class="finger-canvas" data-finger="0" width="280" height="100"></canvas>
              </div>
              <div class="finger-chart-box">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs font-semibold text-text-base">Middle</span>
                  <span class="finger-r2 text-xs text-text-base/40"></span>
                </div>
                <canvas class="finger-canvas" data-finger="1" width="280" height="100"></canvas>
              </div>
              <div class="finger-chart-box">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs font-semibold text-text-base">Ring</span>
                  <span class="finger-r2 text-xs text-text-base/40"></span>
                </div>
                <canvas class="finger-canvas" data-finger="2" width="280" height="100"></canvas>
              </div>
              <div class="finger-chart-box">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs font-semibold text-text-base">Pinky</span>
                  <span class="finger-r2 text-xs text-text-base/40"></span>
                </div>
                <canvas class="finger-canvas" data-finger="3" width="280" height="100"></canvas>
              </div>
            </div>
            <!-- Controls & legend -->
            <div class="flex items-center justify-between mt-3 px-1">
              <div class="flex gap-4 text-sm text-text-base/70 font-medium">
                <span class="flex items-center gap-1.5">
                  <span class="inline-block w-4 h-0.5 rounded" style="background:#6FBEE6"></span> Actual (LASK5)
                </span>
                <span class="flex items-center gap-1.5">
                  <span class="inline-block w-4 h-0.5 rounded" style="background:#FF9F63"></span> Predicted (ML)
                </span>
              </div>
              <button id="hero-play" class="text-xs px-3 py-1 rounded-full bg-orange-primary/20 text-orange-bold hover:bg-orange-primary/40 transition-colors font-medium">
                ▶ Play
              </button>
            </div>
            <div class="mt-2 px-1">
              <p class="text-sm text-text-base/80 leading-snug font-medium">
                ⚠ Proof of concept — very small dataset (~683 samples). Results reflect early-stage research under optimal conditions. Larger datasets and hardware revisions are expected to improve accuracy.
              </p>
            </div>
            <!-- Logo under disclaimer -->
            <div class="mt-6 flex justify-center">
              <img src="/logos/logo-horizontal-black.png" alt="OpenMuscle" class="h-16 sm:h-20 opacity-80" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Is OpenMuscle -->
  <section class="bg-white/60 border-y border-blue-light/20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          What is <span class="text-orange-bold">Open</span><span class="text-blue-primary">Muscle</span>?
        </h2>
        <p class="text-lg text-text-base/60 leading-relaxed">
          An open-source biosensing ecosystem for wearable prosthetic control.
          We use pressure myography &mdash; not EMG &mdash; to detect muscle contractions
          and predict individual finger movements in real time.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1: Open Hardware -->
        <div class="card group">
          <div class="w-12 h-12 rounded-lg bg-orange-light/50 flex items-center justify-center mb-4 group-hover:bg-orange-light transition-colors">
            <svg class="w-6 h-6 text-orange-bold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Open Hardware</h3>
          <p class="text-text-base/60 text-sm leading-relaxed">
            ESP32-S3 microcontrollers, custom flexible PCBs, 3D-printed enclosures.
            FlexGrid packs 60 sensors into a 15&times;4 grid at just 3mm thick.
            All designs released under CERN-OHL-S v2.0.
          </p>
        </div>

        <!-- Card 2: Machine Learning -->
        <div class="card group">
          <div class="w-12 h-12 rounded-lg bg-blue-pale/50 flex items-center justify-center mb-4 group-hover:bg-blue-light transition-colors">
            <svg class="w-6 h-6 text-blue-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Machine Learning</h3>
          <p class="text-text-base/60 text-sm leading-relaxed">
            Random Forest Regressors predict finger movements from pressure data.
            The LASK5 labeling device captures ground-truth training data.
            Python pipelines process UDP sensor streams in real time.
          </p>
        </div>

        <!-- Card 3: Community Driven -->
        <div class="card group">
          <div class="w-12 h-12 rounded-lg bg-orange-light/50 flex items-center justify-center mb-4 group-hover:bg-orange-light transition-colors">
            <svg class="w-6 h-6 text-orange-bold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Community Driven</h3>
          <p class="text-text-base/60 text-sm leading-relaxed">
            Collaborators worldwide: Ultimate Robotics (EMG, Ukraine),
            Delta Robotics (artificial muscles), PCBWay sponsor, devEco group.
            Featured on Hackaday and Electromaker.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works (Brief) -->
  <section class="relative blueprint-grid overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-[0.05]" style="background-image: url('/images/backgrounds/om12-lask5.png');"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-16">
        How It <span class="text-blue-primary">Works</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <!-- Step 1 -->
        <div class="relative text-center px-4">
          <div class="w-14 h-14 rounded-full bg-orange-primary/20 border-2 border-orange-primary flex items-center justify-center mx-auto mb-4">
            <span class="text-xl font-bold text-orange-bold">1</span>
          </div>
          <h3 class="font-semibold mb-2">Wear</h3>
          <p class="text-sm text-text-base/60">FlexGrid wraps around the forearm with 60 pressure sensors detecting muscle topology changes</p>
          <div class="hidden md:block absolute top-7 -right-2 w-8">
            <svg class="w-full text-blue-primary/40" viewBox="0 0 24 8" fill="none" stroke="currentColor"><path stroke-dasharray="3 3" d="M0 4h20m-4-4l4 4-4 4"/></svg>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative text-center px-4">
          <div class="w-14 h-14 rounded-full bg-blue-light/30 border-2 border-blue-primary flex items-center justify-center mx-auto mb-4">
            <span class="text-xl font-bold text-blue-primary">2</span>
          </div>
          <h3 class="font-semibold mb-2">Sense</h3>
          <p class="text-sm text-text-base/60">Sensors capture pressure myography data and transmit via UDP over WiFi from ESP32-S3</p>
          <div class="hidden md:block absolute top-7 -right-2 w-8">
            <svg class="w-full text-orange-primary/40" viewBox="0 0 24 8" fill="none" stroke="currentColor"><path stroke-dasharray="3 3" d="M0 4h20m-4-4l4 4-4 4"/></svg>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="relative text-center px-4">
          <div class="w-14 h-14 rounded-full bg-orange-primary/20 border-2 border-orange-primary flex items-center justify-center mx-auto mb-4">
            <span class="text-xl font-bold text-orange-bold">3</span>
          </div>
          <h3 class="font-semibold mb-2">Learn</h3>
          <p class="text-sm text-text-base/60">LASK5 captures labeled finger positions. Random Forest models train on paired sensor + label data</p>
          <div class="hidden md:block absolute top-7 -right-2 w-8">
            <svg class="w-full text-blue-primary/40" viewBox="0 0 24 8" fill="none" stroke="currentColor"><path stroke-dasharray="3 3" d="M0 4h20m-4-4l4 4-4 4"/></svg>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="text-center px-4">
          <div class="w-14 h-14 rounded-full bg-blue-light/30 border-2 border-blue-primary flex items-center justify-center mx-auto mb-4">
            <span class="text-xl font-bold text-blue-primary">4</span>
          </div>
          <h3 class="font-semibold mb-2">Predict</h3>
          <p class="text-sm text-text-base/60">ML model predicts individual finger movements in real time from raw pressure readings alone</p>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/technology" class="btn-secondary inline-flex items-center gap-2">
          Deep Dive into the Technology
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Repos -->
  <section class="bg-bg-cool/50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="flex items-center justify-between mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold">
          <span class="text-orange-bold">Explore</span> the Repos
        </h2>
        <a href="/repositories" class="text-blue-primary hover:text-blue-bright font-medium inline-flex items-center gap-1 transition-colors">
          View All
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {repos.length > 0 ? repos.map((repo) => {
          const meta = repoMeta[repo.name] || { tags: [], desc: repo.description || '' };
          const updatedDate = new Date(repo.updated_at).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
          return (
            <a href={repo.html_url} target="_blank" class="card group block">
              <div class="flex items-start justify-between mb-3">
                <h3 class="font-semibold text-lg group-hover:text-orange-bold transition-colors">{repo.name}</h3>
                <svg class="w-5 h-5 text-text-base/30 group-hover:text-blue-primary transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </div>
              <p class="text-sm text-text-base/60 mb-4">{meta.desc}</p>

              {/* GitHub Stats Row */}
              <div class="flex items-center gap-4 mb-4 text-sm text-text-base/50">
                {/* Stars */}
                <span class="inline-flex items-center gap-1">
                  <svg class="w-4 h-4 text-orange-bold" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  <span class="font-medium text-text-base/70">{repo.stargazers_count}</span>
                </span>
                {/* Forks */}
                <span class="inline-flex items-center gap-1">
                  <svg class="w-4 h-4 text-blue-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M6 3a3 3 0 013 3c0 1.13-.63 2.12-1.55 2.63.07.46.18.86.34 1.16.31.6.87 1.02 1.6 1.34C10.24 11.5 11.1 11.7 12 11.7s1.76-.2 2.61-.57c.73-.32 1.29-.74 1.6-1.34.16-.3.27-.7.34-1.16A2.997 2.997 0 0115 6a3 3 0 016 0 3 3 0 01-2.45 2.95c-.07.6-.22 1.18-.5 1.7-.51.98-1.37 1.63-2.32 2.05-.74.33-1.54.53-2.23.64V16.05A2.997 2.997 0 0115 19a3 3 0 11-6 0c0-1.3.84-2.42 2-2.83V13.34c-.69-.11-1.49-.31-2.23-.64-.95-.42-1.81-1.07-2.32-2.05-.28-.52-.43-1.1-.5-1.7A2.997 2.997 0 013 6a3 3 0 013-3z"/></svg>
                  <span class="font-medium text-text-base/70">{repo.forks_count}</span>
                </span>
                {/* Language */}
                {repo.language && (
                  <span class="inline-flex items-center gap-1">
                    <span class="w-2.5 h-2.5 rounded-full" style={`background:${repo.language === 'Python' ? '#3572A5' : repo.language === 'HTML' ? '#e34c26' : repo.language === 'C++' ? '#f34b7d' : '#6FBEE6'}`}></span>
                    <span class="font-medium text-text-base/70">{repo.language}</span>
                  </span>
                )}
                {/* Updated */}
                <span class="ml-auto text-xs text-text-base/40">Updated {updatedDate}</span>
              </div>

              <div class="flex gap-3 text-xs">
                {meta.tags.map((tag: string) => (
                  <span class="px-2 py-1 rounded-full bg-orange-light/50 text-orange-bold">{tag}</span>
                ))}
              </div>
            </a>
          );
        }) : (
          /* Fallback static cards if API fails */
          <p class="text-text-base/50 col-span-3 text-center">Loading repo data...</p>
        )}
      </div>

      {/* Org-wide stats bar */}
      {orgStars > 0 && (
        <div class="mt-8 flex items-center justify-center gap-8 text-sm text-text-base/50">
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4 text-orange-bold" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span class="font-semibold text-text-base/70">{orgStars}</span> total stars across org
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4 text-blue-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
            <span class="font-semibold text-text-base/70">{orgRepoCount}</span> repositories
          </span>
        </div>
      )}
    </div>
  </section>

  <!-- Origin Story Teaser -->
  <section class="blueprint-grid">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="relative card bg-white/80 p-8 sm:p-12">
        <div class="absolute -top-4 left-8 text-6xl text-orange-primary/30 font-serif leading-none">&ldquo;</div>

        <blockquote class="text-xl sm:text-2xl text-text-base/80 leading-relaxed mb-6 pl-4 border-l-4 border-orange-primary">
          An amputee couldn't take home a prosthetic because of proprietary restrictions.
          That's when I decided &mdash; this technology needs to be free for everyone.
        </blockquote>

        <div class="flex items-center gap-4 pl-4">
          <div>
            <div class="font-semibold text-text-base">Tory</div>
            <div class="text-sm text-text-base/50">Founder, OpenMuscle</div>
          </div>
        </div>

        <div class="mt-6 pl-4">
          <a href="/about" class="text-blue-primary hover:text-blue-bright font-medium inline-flex items-center gap-1 transition-colors">
            Read the full story
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative overflow-hidden bg-navy text-text-light">
    <div class="absolute inset-0 bg-cover bg-center opacity-[0.12]" style="background-image: url('/images/backgrounds/flexgrid-current.png');"></div>
    <div class="absolute inset-0 blueprint-grid-dense opacity-30"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        Help Us Build the Future of <span class="text-orange-primary">Prosthetics</span>
      </h2>
      <p class="text-lg text-text-light/60 max-w-2xl mx-auto mb-8">
        We need testers, developers, and believers. Whether you can wear a sensor,
        write Python, or just spread the word &mdash; there's a place for you.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/get-involved" class="btn-primary">
          Get Involved
        </a>
        <a href="https://github.com/Open-Muscle/OpenMuscle-Hub" target="_blank" class="btn-secondary border-text-light/30 text-text-light hover:bg-text-light/10">
          Star on GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Finger Prediction Replay Script -->
<script>
async function initFingerReplay() {
  const playBtn = document.getElementById('hero-play') as HTMLButtonElement;
  const canvases = document.querySelectorAll('.finger-canvas') as NodeListOf<HTMLCanvasElement>;
  const r2Labels = document.querySelectorAll('.finger-r2') as NodeListOf<HTMLElement>;
  if (!playBtn || canvases.length === 0) return;

  const res = await fetch('/data/flexgrid64_holdout_predictions.json');
  const data = await res.json();

  const fingerNames = ['label_0', 'label_1', 'label_2', 'label_3'];
  const r2Values = [0.782, 0.783, 0.686, 0.390];
  const WINDOW = 120; // samples visible at once
  const nSamples = data.labels['label_0'].length;

  // Colors
  const actualColor = '#6FBEE6';
  const predictedColor = '#FF9F63';
  const gridColor = 'rgba(111,190,230,0.12)';
  const bgColor = '#FEF9F5';

  // Show R² values
  r2Labels.forEach((el, i) => {
    el.textContent = `R² = ${r2Values[i].toFixed(3)}`;
  });

  // Get actual/predicted arrays per finger
  const actuals: number[][] = fingerNames.map(k => data.labels[k]);
  const preds: number[][] = fingerNames.map(k => data.predictions[k]);

  // Find min/max per finger for scaling
  const mins: number[] = [], maxs: number[] = [];
  for (let f = 0; f < 4; f++) {
    let lo = Infinity, hi = -Infinity;
    for (let i = 0; i < nSamples; i++) {
      const a = actuals[f][i], p = preds[f][i];
      if (a < lo) lo = a; if (a > hi) hi = a;
      if (p < lo) lo = p; if (p > hi) hi = p;
    }
    mins.push(lo); maxs.push(hi);
  }

  function drawFinger(canvas: HTMLCanvasElement, fingerIdx: number, cursor: number) {
    const ctx = canvas.getContext('2d')!;
    const w = canvas.width, h = canvas.height;
    const pad = 4;
    const plotW = w - pad * 2, plotH = h - pad * 2;

    ctx.fillStyle = bgColor;
    ctx.fillRect(0, 0, w, h);

    // Draw subtle grid lines
    ctx.strokeStyle = gridColor;
    ctx.lineWidth = 1;
    for (let i = 0; i <= 4; i++) {
      const y = pad + (plotH / 4) * i;
      ctx.beginPath();
      ctx.moveTo(pad, y);
      ctx.lineTo(pad + plotW, y);
      ctx.stroke();
    }

    const start = Math.max(0, cursor - WINDOW);
    const end = cursor;
    const count = end - start;
    if (count < 2) return;

    const lo = mins[fingerIdx], hi = maxs[fingerIdx];
    const range = hi - lo || 1;

    function xPos(i: number): number { return pad + ((i - start) / WINDOW) * plotW; }
    function yPos(val: number): number { return pad + plotH - ((val - lo) / range) * plotH; }

    // Draw actual line
    ctx.beginPath();
    ctx.strokeStyle = actualColor;
    ctx.lineWidth = 2;
    for (let i = start; i < end; i++) {
      const x = xPos(i), y = yPos(actuals[fingerIdx][i]);
      i === start ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Draw predicted line
    ctx.beginPath();
    ctx.strokeStyle = predictedColor;
    ctx.lineWidth = 2;
    for (let i = start; i < end; i++) {
      const x = xPos(i), y = yPos(preds[fingerIdx][i]);
      i === start ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Draw cursor line
    if (count > 0) {
      const cx = xPos(end - 1);
      ctx.strokeStyle = 'rgba(44,44,44,0.15)';
      ctx.lineWidth = 1;
      ctx.setLineDash([3, 3]);
      ctx.beginPath();
      ctx.moveTo(cx, pad);
      ctx.lineTo(cx, pad + plotH);
      ctx.stroke();
      ctx.setLineDash([]);
    }
  }

  // ===== HAND ANIMATION =====
  const handCanvas = document.getElementById('hand-canvas') as HTMLCanvasElement;
  const handCtx = handCanvas ? handCanvas.getContext('2d')! : null;

  function drawHand(
    ctx: CanvasRenderingContext2D,
    cx: number, palmY: number,
    fingerValues: number[],
    color: string, label: string,
    mirror: boolean
  ) {
    const palmW = 70, palmH = 50, palmR = 12;
    const dir = mirror ? -1 : 1;

    // Label above hand
    ctx.fillStyle = color;
    ctx.font = 'bold 11px Inter, system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(label, cx, palmY - 105);

    // Palm — rounded rect
    ctx.fillStyle = color + '18';
    ctx.strokeStyle = color;
    ctx.lineWidth = 2.5;
    ctx.lineJoin = 'round';
    const px = cx - palmW / 2, py = palmY;
    ctx.beginPath();
    ctx.moveTo(px + palmR, py);
    ctx.lineTo(px + palmW - palmR, py);
    ctx.quadraticCurveTo(px + palmW, py, px + palmW, py + palmR);
    ctx.lineTo(px + palmW, py + palmH - palmR);
    ctx.quadraticCurveTo(px + palmW, py + palmH, px + palmW - palmR, py + palmH);
    ctx.lineTo(px + palmR, py + palmH);
    ctx.quadraticCurveTo(px, py + palmH, px, py + palmH - palmR);
    ctx.lineTo(px, py + palmR);
    ctx.quadraticCurveTo(px, py, px + palmR, py);
    ctx.closePath();
    ctx.fill();
    ctx.stroke();

    // Wrist lines
    ctx.strokeStyle = color + '40';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 4]);
    ctx.beginPath();
    ctx.moveTo(cx - 15, palmY + palmH);
    ctx.lineTo(cx - 15, palmY + palmH + 25);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(cx + 15, palmY + palmH);
    ctx.lineTo(cx + 15, palmY + palmH + 25);
    ctx.stroke();
    ctx.setLineDash([]);

    // Finger positions across palm top
    const fingerSpacing = palmW / 5;
    const fingerOffsets = [
      cx - fingerSpacing * 1.5,
      cx - fingerSpacing * 0.5,
      cx + fingerSpacing * 0.5,
      cx + fingerSpacing * 1.5,
    ];
    const fingerLengths = [
      { prox: 28, dist: 20 },  // Index
      { prox: 32, dist: 22 },  // Middle (longest)
      { prox: 30, dist: 20 },  // Ring
      { prox: 24, dist: 16 },  // Pinky (shortest)
    ];
    // Base splay angles (slight fan)
    const baseAngles = [-0.18, -0.06, 0.06, 0.18];
    const lineW = 3.5;

    for (let f = 0; f < 4; f++) {
      const val = Math.max(0, Math.min(1, fingerValues[f]));
      // Curl: 0 = straight up, 1 = curled ~100°
      const curlAngle = val * 1.75; // radians (~100°)
      const baseAngle = baseAngles[f] - Math.PI / 2; // start pointing up
      const fx = fingerOffsets[f];
      const fy = palmY;

      // Proximal phalanx
      const proxLen = fingerLengths[f].prox;
      const proxAngle = baseAngle + curlAngle * 0.5;
      const proxEndX = fx + Math.cos(proxAngle) * proxLen;
      const proxEndY = fy + Math.sin(proxAngle) * proxLen;

      // Distal phalanx
      const distLen = fingerLengths[f].dist;
      const distAngle = proxAngle + curlAngle * 0.5;
      const distEndX = proxEndX + Math.cos(distAngle) * distLen;
      const distEndY = proxEndY + Math.sin(distAngle) * distLen;

      // Draw finger segments
      ctx.strokeStyle = color;
      ctx.lineWidth = lineW;
      ctx.lineCap = 'round';

      // Proximal
      ctx.beginPath();
      ctx.moveTo(fx, fy);
      ctx.lineTo(proxEndX, proxEndY);
      ctx.stroke();

      // Distal
      ctx.beginPath();
      ctx.moveTo(proxEndX, proxEndY);
      ctx.lineTo(distEndX, distEndY);
      ctx.stroke();

      // Knuckle joint circle (dotted)
      ctx.strokeStyle = color + '60';
      ctx.lineWidth = 1.5;
      ctx.setLineDash([2, 2]);
      ctx.beginPath();
      ctx.arc(fx, fy, 3.5, 0, Math.PI * 2);
      ctx.stroke();
      ctx.setLineDash([]);

      // Mid joint circle
      ctx.strokeStyle = color + '50';
      ctx.lineWidth = 1.5;
      ctx.setLineDash([2, 2]);
      ctx.beginPath();
      ctx.arc(proxEndX, proxEndY, 3, 0, Math.PI * 2);
      ctx.stroke();
      ctx.setLineDash([]);

      // Fingertip dot
      ctx.fillStyle = color;
      ctx.beginPath();
      ctx.arc(distEndX, distEndY, 2.5, 0, Math.PI * 2);
      ctx.fill();
    }

    // Thumb (simplified — slight curl based on average)
    const thumbVal = (fingerValues[0] + fingerValues[1]) * 0.3;
    const thumbBaseX = mirror ? cx + palmW / 2 + 2 : cx - palmW / 2 - 2;
    const thumbBaseY = palmY + 15;
    const thumbAngle = (mirror ? -0.3 : 0.3) - Math.PI / 2 + thumbVal * 0.8;
    const thumbMidX = thumbBaseX + Math.cos(thumbAngle) * 20;
    const thumbMidY = thumbBaseY + Math.sin(thumbAngle) * 20;
    const thumbTipAngle = thumbAngle + thumbVal * 0.4;
    const thumbTipX = thumbMidX + Math.cos(thumbTipAngle) * 14;
    const thumbTipY = thumbMidY + Math.sin(thumbTipAngle) * 14;

    ctx.strokeStyle = color;
    ctx.lineWidth = lineW;
    ctx.lineCap = 'round';
    ctx.beginPath();
    ctx.moveTo(thumbBaseX, thumbBaseY);
    ctx.lineTo(thumbMidX, thumbMidY);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(thumbMidX, thumbMidY);
    ctx.lineTo(thumbTipX, thumbTipY);
    ctx.stroke();
    ctx.fillStyle = color;
    ctx.beginPath();
    ctx.arc(thumbTipX, thumbTipY, 2.5, 0, Math.PI * 2);
    ctx.fill();
  }

  function drawHands(cursor: number) {
    if (!handCtx) return;
    const w = handCanvas.width, h = handCanvas.height;

    // Clear
    handCtx.fillStyle = 'rgba(254,249,245,0.6)';
    handCtx.fillRect(0, 0, w, h);

    // Subtle blueprint grid
    handCtx.strokeStyle = 'rgba(111,190,230,0.08)';
    handCtx.lineWidth = 1;
    for (let x = 0; x < w; x += 20) {
      handCtx.beginPath();
      handCtx.moveTo(x, 0);
      handCtx.lineTo(x, h);
      handCtx.stroke();
    }
    for (let y = 0; y < h; y += 20) {
      handCtx.beginPath();
      handCtx.moveTo(0, y);
      handCtx.lineTo(w, y);
      handCtx.stroke();
    }

    // Get current finger values
    const idx = Math.min(cursor - 1, nSamples - 1);
    const actualVals = [actuals[0][idx], actuals[1][idx], actuals[2][idx], actuals[3][idx]];
    const predVals = [preds[0][idx], preds[1][idx], preds[2][idx], preds[3][idx]];

    // Draw actual hand (left, blue)
    drawHand(handCtx, w * 0.28, 110, actualVals, actualColor, 'Actual (LASK5)', false);

    // Draw predicted hand (right, orange)
    drawHand(handCtx, w * 0.72, 110, predVals, predictedColor, 'Predicted (ML)', true);

    // Center divider
    handCtx.strokeStyle = 'rgba(111,190,230,0.15)';
    handCtx.lineWidth = 1;
    handCtx.setLineDash([4, 4]);
    handCtx.beginPath();
    handCtx.moveTo(w / 2, 20);
    handCtx.lineTo(w / 2, h - 10);
    handCtx.stroke();
    handCtx.setLineDash([]);
  }

  function drawAll(cursor: number) {
    canvases.forEach((c) => {
      const finger = parseInt(c.dataset.finger || '0');
      drawFinger(c, finger, cursor);
    });
    drawHands(cursor);
  }

  // Draw initial static frame
  drawAll(WINDOW);

  let playing = false;
  let cursor = WINDOW;
  let animId: number | null = null;
  let lastTime = 0;
  const SPEED = 40; // ms between samples

  function animate(time: number) {
    if (time - lastTime >= SPEED) {
      cursor++;
      if (cursor > nSamples) cursor = WINDOW; // loop
      drawAll(cursor);
      lastTime = time;
    }
    animId = requestAnimationFrame(animate);
  }

  playBtn.addEventListener('click', () => {
    if (playing) {
      if (animId) cancelAnimationFrame(animId);
      animId = null;
      playing = false;
      playBtn.innerHTML = '▶ Play';
    } else {
      lastTime = performance.now();
      animId = requestAnimationFrame(animate);
      playing = true;
      playBtn.innerHTML = '⏸ Pause';
    }
  });
}

initFingerReplay();
</script>
