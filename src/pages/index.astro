<!-- Real Sensor Heatmap Script -->
<script>
async function initHeroHeatmap() {
  const canvas = document.getElementById('sensor-heatmap') as HTMLCanvasElement;
  const playBtn = document.getElementById('hero-play') as HTMLButtonElement;
  if (!canvas || !playBtn) return;

  const ctx = canvas.getContext('2d')!;

  // Load real FlexGrid-64 data
  const res = await fetch('/data/flexgrid64_holdout_predictions.json');
  const data = await res.json();
  const rows = 4, cols = 16;
  const nSamples = data.metadata.n_samples;

  // Build frames from real sensor data
  let globalMin = Infinity, globalMax = -Infinity;
  const frames: number[][][] = [];
  for (let s = 0; s < nSamples; s++) {
    const frame: number[][] = [];
    for (let r = 0; r < rows; r++) {
      const row: number[] = [];
      for (let c = 0; c < cols; c++) {
        const val = data.sensor_data[`R${r}C${c}`][s];
        row.push(val);
        if (val < globalMin) globalMin = val;
        if (val > globalMax) globalMax = val;
      }
      frame.push(row);
    }
    frames.push(frame);
  }

  const cellW = Math.floor((canvas.width - 10) / cols);
  const cellH = Math.floor((canvas.height - 10) / rows);

  function valueToColor(val: number): string {
    const t = (val - globalMin) / (globalMax - globalMin || 1);
    const r = Math.round(111 + (255 - 111) * t);
    const g = Math.round(190 + (159 - 190) * t);
    const b = Math.round(230 + (99 - 230) * t);
    return `rgb(${r},${g},${b})`;
  }

  function drawFrame(idx: number) {
    const frame = frames[idx];
    ctx.fillStyle = '#FEF9F5';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const x = 5 + c * cellW;
        const y = 5 + r * cellH;
        ctx.fillStyle = valueToColor(frame[r][c]);
        ctx.beginPath();
        ctx.roundRect(x, y, cellW - 2, cellH - 2, 3);
        ctx.fill();
      }
    }
  }

  let playing = false;
  let frameIdx = 0;
  let intervalId: number | null = null;

  playBtn.addEventListener('click', () => {
    if (playing) {
      if (intervalId) clearInterval(intervalId);
      intervalId = null;
      playing = false;
      playBtn.textContent = 'Play';
    } else {
      intervalId = window.setInterval(() => {
        frameIdx = (frameIdx + 1) % nSamples;
        drawFrame(frameIdx);
      }, 50);
      playing = true;
      playBtn.textContent = 'Pause';
    }
  });

  drawFrame(0);
}

initHeroHeatmap();
</script>
