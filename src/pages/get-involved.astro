---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Get Involved">
  <section class="blueprint-grid-dense">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6">
        Get <span class="text-blue-primary">Involved</span>
      </h1>
      <p class="text-lg text-text-base/60 max-w-3xl mb-16">
        OpenMuscle is a community-driven project. Whether you're an engineer, developer, researcher,
        or someone who believes in accessible prosthetics, there's a way to contribute.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        <!-- Test Hardware -->
        <div class="card group">
          <div class="w-12 h-12 rounded-lg bg-orange-light/50 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-orange-bold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Test the Hardware</h3>
          <p class="text-text-base/60 text-sm leading-relaxed">
            We need people to wear the FlexGrid and LASK5 to generate diverse training data.
            More testers = better ML models = better prosthetics for everyone.
          </p>
        </div>

        <!-- Write Code -->
        <div class="card group">
          <div class="w-12 h-12 rounded-lg bg-blue-pale/50 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Write Code</h3>
          <p class="text-text-base/60 text-sm leading-relaxed">
            Python, MicroPython, C, firmware, ML pipelines. All repos are MIT/CERN licensed
            and contributions are welcome. Check the GitHub issues for good first tasks.
          </p>
        </div>

        <!-- Spread the Word -->
        <div class="card group">
          <div class="w-12 h-12 rounded-lg bg-orange-light/50 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-orange-bold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Spread the Word</h3>
          <p class="text-text-base/60 text-sm leading-relaxed">
            Star our repos, share our videos, tell a friend. The more people who know about OpenMuscle,
            the faster we can make prosthetic tech accessible to everyone.
          </p>
        </div>
      </div>

      <!-- Links -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="https://github.com/Open-Muscle" target="_blank" class="card group flex items-center gap-4">
          <svg class="w-10 h-10 text-text-base/30 group-hover:text-blue-primary transition-colors flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          <div>
            <h3 class="font-semibold text-lg group-hover:text-orange-bold transition-colors">GitHub Organization</h3>
            <p class="text-sm text-text-base/60">Browse all repositories and open issues</p>
          </div>
        </a>

        <a href="https://www.youtube.com/@TURFPTAx" target="_blank" class="card group flex items-center gap-4">
          <svg class="w-10 h-10 text-text-base/30 group-hover:text-orange-bold transition-colors flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          <div>
            <h3 class="font-semibold text-lg group-hover:text-orange-bold transition-colors">YouTube Channel</h3>
            <p class="text-sm text-text-base/60">Watch build videos, demos, and livestreams</p>
          </div>
        </a>
      </div>

      <!-- Press -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-6">Featured In</h2>
        <div class="flex flex-wrap gap-4">
          <a href="https://hackaday.com/2022/10/20/forearm-muscle-contraction-sensor-is-useful-component-for-open-source-prosthetics/" target="_blank" class="card group inline-flex items-center gap-2 py-3 px-5">
            <span class="font-medium group-hover:text-orange-bold transition-colors">Hackaday — Forearm Sensor (2022)</span>
            <svg class="w-4 h-4 text-text-base/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
          <a href="https://hackaday.com/2023/05/12/hackaday-prize-2023-finger-tracking-via-muscle-sensors/" target="_blank" class="card group inline-flex items-center gap-2 py-3 px-5">
            <span class="font-medium group-hover:text-orange-bold transition-colors">Hackaday Prize — Finger Tracking (2023)</span>
            <svg class="w-4 h-4 text-text-base/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
          <a href="https://hackaday.com/2023/06/02/hackaday-prize-2023-lask4-watches-those-finger-wiggles/" target="_blank" class="card group inline-flex items-center gap-2 py-3 px-5">
            <span class="font-medium group-hover:text-orange-bold transition-colors">Hackaday Prize — LASK4 (2023)</span>
            <svg class="w-4 h-4 text-text-base/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
          <a href="https://www.electromaker.io/project/view/open-muscle-sensor-band" target="_blank" class="card group inline-flex items-center gap-2 py-3 px-5">
            <span class="font-medium group-hover:text-orange-bold transition-colors">Electromaker</span>
            <svg class="w-4 h-4 text-text-base/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
