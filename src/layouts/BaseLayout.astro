---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Open-source prosthetic sensor technology for all humanity. Affordable pressure myography sensors that predict finger movements using machine learning." } = Astro.props;

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FEF9F5" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title} | OpenMuscle</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-bg-warm/90 backdrop-blur-md border-b border-blue-light/40">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 group">
            <img
              src="/logos/logo-horizontal-black.png"
              alt="OpenMuscle"
              class="h-8 sm:h-10 transition-transform group-hover:scale-105"
            />
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-8">
            <a href="/" class="text-text-base/70 hover:text-orange-bold font-medium transition-colors">Home</a>
            <a href="/technology" class="text-text-base/70 hover:text-orange-bold font-medium transition-colors">Technology</a>
            <a href="/repositories" class="text-text-base/70 hover:text-orange-bold font-medium transition-colors">Repositories</a>
            <a href="/get-involved" class="text-text-base/70 hover:text-orange-bold font-medium transition-colors">Get Involved</a>
            <a href="/about" class="text-text-base/70 hover:text-orange-bold font-medium transition-colors">About</a>
            <a
              href="https://github.com/Open-Muscle"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary text-sm py-2 px-4 inline-flex items-center gap-2"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              GitHub
            </a>
          </div>

          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 text-text-base/70 hover:text-orange-bold">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <div class="flex flex-col gap-3">
            <a href="/" class="text-text-base/70 hover:text-orange-bold font-medium py-2">Home</a>
            <a href="/technology" class="text-text-base/70 hover:text-orange-bold font-medium py-2">Technology</a>
            <a href="/repositories" class="text-text-base/70 hover:text-orange-bold font-medium py-2">Repositories</a>
            <a href="/get-involved" class="text-text-base/70 hover:text-orange-bold font-medium py-2">Get Involved</a>
            <a href="/about" class="text-text-base/70 hover:text-orange-bold font-medium py-2">About</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white/60 border-t border-blue-light/40 mt-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Brand -->
          <div class="md:col-span-1">
            <img src="/logos/logo-black.png" alt="OpenMuscle" class="h-16 mb-4" />
            <p class="text-sm text-text-base/60">
              Open prosthetic sensor technology for all humanity.
            </p>
          </div>

          <!-- Links -->
          <div>
            <h4 class="font-semibold text-text-base mb-3">Project</h4>
            <ul class="space-y-2 text-sm text-text-base/60">
              <li><a href="/technology" class="hover:text-blue-primary transition-colors">Technology</a></li>
              <li><a href="/repositories" class="hover:text-blue-primary transition-colors">Repositories</a></li>
              <li><a href="/about" class="hover:text-blue-primary transition-colors">About</a></li>
            </ul>
          </div>

          <div>
            <h4 class="font-semibold text-text-base mb-3">Community</h4>
            <ul class="space-y-2 text-sm text-text-base/60">
              <li><a href="https://github.com/Open-Muscle" target="_blank" class="hover:text-blue-primary transition-colors">GitHub</a></li>
              <li><a href="https://www.youtube.com/@TURFPTAx" target="_blank" class="hover:text-blue-primary transition-colors">YouTube</a></li>
              <li><a href="/get-involved" class="hover:text-blue-primary transition-colors">Get Involved</a></li>
            </ul>
          </div>

          <div>
            <h4 class="font-semibold text-text-base mb-3">Licenses</h4>
            <ul class="space-y-2 text-sm text-text-base/60">
              <li>Software: MIT</li>
              <li>Hardware: CERN-OHL-S v2.0</li>
              <li>Docs: Creative Commons</li>
            </ul>
          </div>
        </div>

        <div class="solid-line-h mt-8 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-sm text-text-base/50">
            &copy; {new Date().getFullYear()} OpenMuscle. Open source, open hardware, open for humanity.
          </p>
          <div class="flex items-center gap-4">
            <a href="https://github.com/Open-Muscle" target="_blank" class="text-text-base/40 hover:text-blue-primary transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            </a>
            <a href="https://www.youtube.com/@TURFPTAx" target="_blank" class="text-text-base/40 hover:text-orange-bold transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Mobile Menu Script -->
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
